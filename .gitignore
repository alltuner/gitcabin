__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Runtime state — bare repos with code + metadata refs written by the server
data/

# Bundled frontend assets — produced from web-src/ at build time. Tracked
