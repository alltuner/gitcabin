# cgit configuration. The full reference is at /usr/share/doc/cgit/cgitrc.5.
# We keep this minimal: scan-path lets cgit auto-discover any bare repo under
# /repos at request time, so new <owner>/<name>.git directories show up
# without restarting the container.

# Page chrome.
root-title=testgit
root-desc=Browse the bare repos backing testgit (code refs and metadata refs).
css=/cgit-css/cgit.css
favicon=/cgit-css/favicon.ico
# Point logo at the asset cgit ships alongside the css instead of the default
# /cgit.png, which 404s under the Apache config we use here.
logo=/cgit-css/cgit.png

# Strip the trailing ".git" from displayed repo names — purely cosmetic.
remove-suffix=1

# Display the side refs that hold issue/PR/counter data, not just heads/tags.
# Without this, refs/issues/local/* would be invisible in the UI.
enable-remote-branches=1

# Auto-discover repos under this directory at request time.
scan-path=/repos

# Generate URLs relative to the site root rather than to the cgit.cgi
# script path, so links read like /octocat/hello/log/ instead of
# /cgit.cgi/octocat/hello/log/.
virtual-root=/
